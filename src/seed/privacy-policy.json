{
  "id": 2,
  "title": "Privacy Policy",
  "slug": "privacy-policy",

  "content": {
    "root": {
      "type": "root",
      "format": "",
      "indent": 0,
      "version": 1,

      "children": [
        {
          "tag": "h1",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "Privacy Policy",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "tag": "h3",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "1. Information Collected",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "When you interact with our website or use our software, we collect the following information:",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "tag": "ol",
          "type": "list",
          "start": 1,
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "type": "listitem",
              "value": 1,
              "format": "",
              "indent": 0,
              "version": 1,

              "children": [
                {
                  "text": "Account Data: We collect your email address to provide access to the user panel, validate software licenses, and communicate essential updates or account information.",
                  "type": "text",
                  "version": 1
                }
              ],
              "direction": "ltr"
            },

            {
              "type": "listitem",
              "value": 2,
              "format": "",
              "indent": 0,
              "version": 1,

              "children": [
                {
                  "text": "Device and License Data: We collect information regarding your operating system and computer username to manage your active installations and ensure proper license validation.",
                  "type": "text",
                  "version": 1
                }
              ],
              "direction": "ltr"
            },

            {
              "type": "listitem",
              "value": 3,
              "format": "",
              "indent": 0,
              "version": 1,

              "children": [
                {
                  "text": "Transaction Data: When you make a purchase, we collect data about the products purchased and the transaction amount.",
                  "type": "text",
                  "version": 1
                }
              ],
              "direction": "ltr"
            }
          ],
          "listType": "number",
          "direction": "ltr"
        },

        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "Payment Security: We do not store your credit card or payment method details on our servers. All payments are processed securely by our third-party payment providers.",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "tag": "h3",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "2. Use of Collected Information",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "tag": "ol",
          "type": "list",
          "start": 1,
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "type": "listitem",
              "value": 1,
              "format": "",
              "indent": 0,
              "version": 1,

              "children": [
                {
                  "text": "Service Delivery: To manage user accounts, provide access to personalized features, and validate software activations.",
                  "type": "text",
                  "version": 1
                }
              ],
              "direction": "ltr"
            },

            {
              "type": "listitem",
              "value": 2,
              "format": "",
              "indent": 0,
              "version": 1,

              "children": [
                {
                  "text": "Communication: To send relevant emails, technical notifications, and support responses.",
                  "type": "text",
                  "version": 1
                }
              ],
              "direction": "ltr"
            },

            {
              "type": "listitem",
              "value": 3,
              "format": "",
              "indent": 0,
              "version": 1,

              "children": [
                {
                  "text": "Analytics: We use basic Google Analytics to measure website traffic and improve our services.",
                  "type": "text",
                  "version": 1
                }
              ],
              "direction": "ltr"
            },

            {
              "type": "listitem",
              "value": 4,
              "format": "",
              "indent": 0,
              "version": 1,

              "children": [
                {
                  "text": "Sales Transactions: To process orders, fulfill purchases, and comply with tax and legal obligations.",
                  "type": "text",
                  "version": 1
                }
              ],
              "direction": "ltr"
            }
          ],
          "listType": "number",
          "direction": "ltr"
        },

        {
          "tag": "h3",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "3. Data Security",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "We take data security seriously. We implement appropriate technical and organizational measures—such as encryption and secure access controls—to protect your data from unauthorized access, loss, or misuse.",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "tag": "h3",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "4. User Rights",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "tag": "ol",
          "type": "list",
          "start": 1,
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "type": "listitem",
              "value": 1,
              "format": "",
              "indent": 0,
              "version": 1,

              "children": [
                {
                  "text": "Access: Request access to the personal data we hold about you.",
                  "type": "text",
                  "version": 1
                }
              ],
              "direction": "ltr"
            },

            {
              "type": "listitem",
              "value": 2,
              "format": "",
              "indent": 0,
              "version": 1,

              "children": [
                {
                  "text": "Rectification: Correct any inaccuracies in your data.",
                  "type": "text",
                  "version": 1
                }
              ],
              "direction": "ltr"
            },

            {
              "type": "listitem",
              "value": 3,
              "format": "",
              "indent": 0,
              "version": 1,

              "children": [
                {
                  "text": "Erasure: Request the deletion of your account and associated data.",
                  "type": "text",
                  "version": 1
                }
              ],
              "direction": "ltr"
            },

            {
              "type": "listitem",
              "value": 4,
              "format": "",
              "indent": 0,
              "version": 1,

              "children": [
                {
                  "text": "Object: Object to or restrict the processing of your data.",
                  "type": "text",
                  "version": 1
                }
              ],
              "direction": "ltr"
            }
          ],
          "listType": "number",
          "direction": "ltr"
        },

        {
          "tag": "h3",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "5. Cookies and Tracking",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "Our website uses cookies to enable core functionality (such as keeping you logged in) and to analyze website traffic. You can adjust your browser settings to manage cookies.",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "tag": "h3",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "6. Data Retention",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "We retain your information for as long as your account is active or as needed to provide you with software updates and support.",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "tag": "h3",
          "type": "heading",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "7. Contact Information",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        },

        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,

          "children": [
            {
              "text": "If you have any questions or concerns about our privacy policy, please contact us at mxbeats.com/contact.",
              "type": "text",
              "version": 1
            }
          ],
          "direction": "ltr"
        }
      ],
      "direction": "ltr"
    }
  },

