NODE_ENV=production
DATABASE_URL=postgres://user:password@localhost:5432/mxbeats
PAYLOAD_SECRET=your_payload_secret_here

# Email (Contact Form)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=your_smtp_password
CONTACT_EMAIL=contact@example.com

# Static files CDN
NEXT_PUBLIC_STATIC_URL=https://static.example.com/

# Server URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# RSA Keys (for license/installation encryption)
RSA_PRIVATE_KEY=your_rsa_private_key_hex
RSA_PUBLIC_KEY=your_rsa_public_key_hex

# Installation limits
MAX_INSTALLATIONS=2

# Rate limiter logging
# false = disabled, true = log events to stdout/stderr
RATE_LIMITER_LOG_ENABLED=false
# blocked = log only rejected requests, all = log allowed and rejected requests,
# summary = log aggregated counts per limiter once per interval
RATE_LIMITER_LOG_MODE=blocked
# summary interval in milliseconds; used only when RATE_LIMITER_LOG_MODE=summary
RATE_LIMITER_LOG_SUMMARY_INTERVAL_MS=60000

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@ingest.sentry.io/project-id
SENTRY_AUTH_TOKEN=your_sentry_auth_token
